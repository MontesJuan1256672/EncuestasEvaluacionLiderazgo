@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;

    var tiposEvaluacion = ViewBag.TiposEvaluacion as System.Data.DataTable;
    var ciudades = ViewBag.Ciudades as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Evaluación de Liderazgo</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-blue-600 to-blue-800 min-h-screen flex items-center justify-center">
    <div class="max-w-md w-full">
        <!-- Card de Login -->
        <div class="bg-white rounded-lg shadow-2xl p-8">
            <!-- Logo/Header -->
            <div class="text-center mb-8">
                <div class="inline-block text-5xl mb-4">📊</div>
                <h1 class="text-3xl font-bold text-gray-800">Evaluación Liderazgo</h1>
                <p class="text-gray-600 mt-2">Sistema de Evaluación de Competencias</p>
            </div>

            <!-- Mensaje de agradecimiento -->
            @if (TempData["Gracias"] != null)
            {
                <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded mb-4">
                    <p class="font-bold">@TempData["Gracias"]</p>
                </div>
            }

            <!-- Formulario de Login -->
            <form asp-action="Login" method="post" class="space-y-4">
                <!-- Validación general -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded" role="alert">
                        <p class="font-bold">Error de autenticación</p>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <p class="text-sm">• @error.ErrorMessage</p>
                            }
                        }
                    </div>
                }

                <!-- Tipo de Acceso -->
                <div>
                    <label for="tipoAcceso" class="block text-gray-700 font-semibold mb-2">Tipo de Acceso</label>
                    <select id="tipoAcceso" name="tipoAcceso"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
                        <option value="1">Empleado</option>
                        <option value="2">Administrador</option>
                        <option value="3">Consulta</option>
                    </select>
                </div>

                <!-- Tipo de Encuesta -->
                <div>
                    <label for="cmbTipoEnc" class="block text-gray-700 font-semibold mb-2">Tipo de Encuesta</label>
                    <select id="cmbTipoEnc" name="cmbTipoEnc"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
                        @if (tiposEvaluacion != null)
                        {
                            @foreach (System.Data.DataRow row in tiposEvaluacion.Rows)
                            {
                                <option value="@row["IdTipoEvaluacion"]">@row["cDescripcion"]</option>
                            }
                        }
                    </select>
                </div>

                <!-- Centro -->
                <div>
                    <label for="cmbCentro" class="block text-gray-700 font-semibold mb-2">Centro</label>
                    <select id="cmbCentro" name="cmbCentro"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
                        @if (ciudades != null)
                        {
                            @foreach (var item in ciudades)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>

                <!-- Clave de Acceso -->
                <div id="divClave">
                    <label for="txtClave" class="block text-gray-700 font-semibold mb-2">Clave de Acceso</label>
                    <input type="text" id="txtClave" name="txtClave"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
                        placeholder="Ingrese la clave de acceso" />
                </div>

                <!-- Botón Login -->
                <button type="submit" class="w-full bg-blue-600 text-white font-bold py-2 rounded-lg hover:bg-blue-700 transition duration-300 mt-6">
                    Iniciar Sesión
                </button>
            </form>
        </div>

        <!-- Footer -->
        <div class="text-center mt-8 text-white">
            <p class="text-sm opacity-75">
                © 2026 Sistema de Evaluación de Liderazgo. Todos los derechos reservados.
            </p>
        </div>
    </div>

    <script>
        // Mostrar/ocultar campos según el tipo de acceso
        document.getElementById('tipoAcceso').addEventListener('change', function () {
            const tipo = this.value;
            const divClave = document.getElementById('divClave');
            const cmbTipoEnc = document.getElementById('cmbTipoEnc');

            // Clave y tipo encuesta solo visibles para Empleado (1)
            divClave.style.display = tipo === '1' ? 'block' : 'none';
            cmbTipoEnc.closest('div').style.display = tipo === '1' ? 'block' : 'none';
        });
    </script>
</body>
</html>
