@model IEnumerable<PersonaEvaluar>

@{
    ViewData["Title"] = "Gestión de Personas a Evaluar";
}

<div class="py-8">
    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-4xl font-bold text-gray-900">👥 Personas a Evaluar</h1>
            <p class="text-gray-600 mt-2">Gestiona el personal que será objeto de evaluación de liderazgo</p>
        </div>
        <a asp-action="Create" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition inline-flex items-center space-x-2">
            <span>➕</span>
            <span>Agregar Persona</span>
        </a>
    </div>

    <!-- Alertas -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-6 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative">
            <span class="block sm:inline">✓ @TempData["Success"]</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="mb-6 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
            <span class="block sm:inline">✗ @TempData["Error"]</span>
        </div>
    }

    <!-- Filtros (Combobox) -->
    <div class="mb-6">
        <select id="filtroTipoEvaluacion" asp-items="ViewBag.TiposEvaluacion" 
                class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                value="@ViewBag.FiltroTipoEvaluacionActual">
        </select>
    </div>

    <!-- Tabla de Personas -->
    @if (Model.Any())
    {
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-100 border-b">
                    <tr>
                        <th class="px-6 py-3 text-left text-sm font-bold text-gray-700">Número Empleado</th>
                        <th class="px-6 py-3 text-left text-sm font-bold text-gray-700">Ciudad</th>
                        <th class="px-6 py-3 text-left text-sm font-bold text-gray-700">Nombre</th>
                        <th class="px-6 py-3 text-left text-sm font-bold text-gray-700">Puesto</th>
                        <th class="px-6 py-3 text-left text-sm font-bold text-gray-700">Estado</th>
                        <th class="px-6 py-3 text-center text-sm font-bold text-gray-700">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var persona in Model)
                    {
                        <tr class="border-b hover:bg-gray-50 transition">
                            <td class="px-6 py-4 text-sm text-gray-900 font-semibold">@persona.NumeroEmpleado</td>
                            <td class="px-6 py-4 text-sm text-gray-600">@persona.Ciudad</td>
                            <td class="px-6 py-4 text-sm text-gray-600">@persona.Nombre</td>
                            <td class="px-6 py-4 text-sm text-gray-600">@persona.Puesto</td>
                            <td class="px-6 py-4 text-sm">
                                @if (persona.Activo)
                                {
                                    <span class="bg-green-100 text-green-800 text-xs font-bold px-3 py-1 rounded-full">Activo</span>
                                }
                                else
                                {
                                    <span class="bg-red-100 text-red-800 text-xs font-bold px-3 py-1 rounded-full">Inactivo</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-center text-sm">
                                <div class="flex justify-center space-x-2">
                                    <a asp-action="Edit" asp-route-id="@persona.IDPersona" 
                                       class="bg-yellow-100 text-yellow-600 px-3 py-1 rounded hover:bg-yellow-200 transition font-semibold text-xs">
                                        ✏️ Editar
                                    </a>
                                    <form method="post" asp-action="Delete" asp-route-id="@persona.IDPersona" 
                                          style="display:inline;" onsubmit="return confirm('¿Estás seguro de eliminar esta persona?');">
                                        <button type="submit" class="bg-red-100 text-red-600 px-3 py-1 rounded hover:bg-red-200 transition font-semibold text-xs">
                                            🗑️ Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow-md p-8 text-center">
            <p class="text-gray-600 text-lg mb-4">No hay personas registradas aún</p>
            <a asp-action="Create" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition inline-flex items-center space-x-2">
                <span>➕</span>
                <span>Agregar Primera Persona</span>
            </a>
        </div>
    }

    <!-- Botón Volver -->
    <div class="mt-8">
        <a asp-controller="Home" asp-action="Index" class="bg-gray-300 text-gray-800 px-6 py-3 rounded-lg hover:bg-gray-400 transition font-bold">
            ← Volver al Inicio
        </a>
    </div>
</div>

<script>
    // Manejar cambios en el filtro de tipo de evaluación
    document.addEventListener('DOMContentLoaded', function() {
        const filtroSelect = document.getElementById('filtroTipoEvaluacion');
        
        if (!filtroSelect) {
            return;
        }

        // Establecer el valor seleccionado actual
        const valorActual = '@ViewBag.FiltroTipoEvaluacionActual';
        
        if (valorActual) {
            filtroSelect.value = valorActual;
        }

        // Escuchar cambios en el select
        filtroSelect.addEventListener('change', function () {
            const idTipoEvaluacion = this.value;
            
            // Obtener la ruta base desde la URL actual analizando el pathname
            // URL actual: /Des/EncuestasEvaluacionLiderazgo/PersonasEvaluar
            // Necesitamos extraer: /Des/EncuestasEvaluacionLiderazgo
            const pathname = window.location.pathname;
            
            // Encontrar dónde termina "/PersonasEvaluar" y extraer el prefijo
            const controllerName = 'PersonasEvaluar';
            const indexOfController = pathname.lastIndexOf('/' + controllerName);
            
            let pathBase = '';
            if (indexOfController !== -1) {
                pathBase = pathname.substring(0, indexOfController);
            } else {
                pathBase = pathname.split('/').slice(0, -1).join('/');
            }
            
            // Construir URL con el PathBase correcto
            const urlDestino = pathBase + '/PersonasEvaluar?idTipoEvaluacion=' + encodeURIComponent(idTipoEvaluacion);
            
            // Redirigir a la URL con el parámetro del filtro
            window.location.href = urlDestino;
        });
    });
</script>
